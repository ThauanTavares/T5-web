<%= form_with(model: curso, class: "needs-validation") do |form| %>
    <% if curso.errors.any? %>
      <div style="color: red">
        <h2><%= pluralize(curso.errors.count, "error") %> prohibited this curso from being saved:</h2>
  
        <ul>
          <% curso.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  
    <div class="mb-3">
      <%= form.label :nome, "Nome do Curso", class: "form-label" %>
      <%= form.text_field :nome, class: "form-control" %>
    </div>
  
    <div class="d-grid gap-2">
      <%= form.submit "Salvar Curso", class: "btn btn-primary" %>
    </div>
  <% end %>